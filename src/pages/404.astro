---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Global Events">
  <main style="flex: 1; display: flex; align-items: center; justify-content: center; padding: 150px 20px 80px; text-align: center;">
    <div class="error-container">
      <h1 style="font-family: 'Cinzel', serif; font-size: 8rem; color: #BF953F; margin: 0; line-height: 1; text-shadow: 0 0 20px rgba(191, 149, 63, 0.3);">404</h1>
      <h2 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin: 20px 0; color: #fff;">El espectáculo no está aquí</h2>
      <p style="color: #aaa; font-family: 'Barlow', sans-serif; max-width: 500px; margin: 0 auto 40px; line-height: 1.6;">
        Parece que te has perdido entre bambalinas. El artista o la página que buscas no existe o ha cambiado de escenario.
      </p>
      <a href="/" class="btn btn--gold" style="font-size: 1.1rem; padding: 15px 30px;">
        Volver a la Home
      </a>
    </div>
  </main>
</Layout>